# Configuración del servidor de correo
# Copie este archivo como .env y rellene los valores

# Puerto del servidor (por defecto 3000)
PORT=3000

# Usuario de Gmail (la cuenta que envía los correos)
SMTP_USER=tu-correo@gmail.com

# Contraseña de aplicación de Gmail
# Pasos para obtenerla:
# 1. Activar verificación en dos pasos en tu cuenta Google
# 2. Ir a: Cuenta de Google → Seguridad → Contraseñas de aplicaciones
# 3. Crear una contraseña para "Correo" / "Otro"
# 4. Pegar los 16 caracteres aquí (sin espacios)
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Email donde se recibirán las consultas del formulario
RECIPIENT_EMAIL=jmgilprocurador@gmail.com
